# Allowlist: this repository publishes only what a person needs to build the app,
# plus the README and the screenshots it shows. Everything else — working notes,
# operating docs, plans, test scaffolding, private material, build output, release
# artifacts (they live on the Releases page) — stays local by design.
#
# Ignore everything, then re-allow the public surface, so a new file is never
# published by accident.

/*

!/.gitignore
!/README.md
!/LICENSE

# Sources and resources needed to compile the APK.
!/src/

# Build scripts needed to produce the APK.
!/scripts/
/scripts/*
!/scripts/env.sh
!/scripts/build.sh
!/scripts/add-to-zip.py

# Regenerates the launcher icons that live in src/.
!/tools/
/tools/*
!/tools/make-icons.py

# Only the screenshots the README embeds.
!/docs/
/docs/*
!/docs/screenshots/

# Local toolchain paths and signing material are never published.
scripts/env.local.sh
*.keystore
*.idsig
